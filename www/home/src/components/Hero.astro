---
import { site, badge, hero } from '../data/content';
import InstallCommand from './InstallCommand.astro';
---

<div class="hero">
  <div class="badge">
    <span class="badge-dot"></span>
    <span class="badge-label">{badge.label}</span>
  </div>

  <div class="logo-row">
    <div class="logo">
      <span>n</span>
    </div>
  </div>

  <h1 class="headline">
    {hero.headline}<span class="cursor">_</span>
  </h1>
  <p class="subtext">{hero.subtext}</p>

  <div class="cta-row">
    <InstallCommand />
    <a href={site.repoUrl} class="source-link" target="_blank" rel="noopener noreferrer">
      {hero.sourceLinkLabel}
    </a>
  </div>
</div>

<style>
  .hero {
    padding: clamp(48px, 10vw, 76px) var(--content-padding-x) 0;
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .badge {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 28px;
    border: 1px solid var(--color-panel-border-strong);
    border-radius: 20px;
    padding: 6px 14px;
    background: rgba(255, 255, 255, 0.02);
  }

  .badge-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-warning);
    display: inline-block;
    box-shadow: 0 0 8px rgba(234, 179, 8, 0.7);
  }

  .badge-label {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--color-warning);
    letter-spacing: 0.04em;
  }

  .logo-row {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 8px;
  }

  .logo {
    width: clamp(44px, 10vw, 56px);
    height: clamp(44px, 10vw, 56px);
    border-radius: 14px;
    background: var(--gradient-accent);
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 8px 28px var(--color-accent-glow), inset 0 1px 0 rgba(255, 255, 255, 0.25);
  }

  .logo span {
    font-family: var(--font-mono);
    font-weight: 800;
    font-size: clamp(22px, 5vw, 28px);
    color: #fff;
  }

  .headline {
    margin: 0 0 20px;
    font-family: var(--font-mono);
    font-size: var(--font-size-headline);
    color: var(--color-text-heading);
    font-weight: 600;
    letter-spacing: 0.01em;
    max-width: 40ch;
  }

  .cursor {
    color: var(--color-accent);
    animation: blink 1.1s step-end infinite;
  }

  .subtext {
    margin: 0 0 40px;
    font-size: var(--font-size-subtext);
    color: var(--color-text-body);
    max-width: 560px;
    line-height: 1.7;
  }

  .cta-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 14px;
    margin-bottom: clamp(40px, 8vw, 64px);
    max-width: 100%;
  }

  .source-link {
    font-family: var(--font-mono);
    font-size: 14px;
    color: var(--color-text-heading);
    text-decoration: none;
    border-bottom: 1px solid var(--color-text-faintest);
    padding-bottom: 2px;
    white-space: nowrap;
    transition: color 0.15s ease, border-color 0.15s ease;
  }

  .source-link:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }
</style>
