---
import { site } from '../lib/site';

export interface Props {
  /** Relative link to this site's own index (docs/README.md). */
  indexHref: string;
  /** Relative link back to the landing page (a separate Astro project,
   *  deployed one level above this one — see the CI workflow). */
  homeHref: string;
}

const { indexHref, homeHref } = Astro.props;
---

<header class="docs-header">
  <div class="docs-header-inner">
    <button type="button" class="nav-toggle" id="docs-nav-toggle" aria-label="Toggle navigation" aria-controls="docs-sidebar" aria-expanded="false">
      <span></span>
      <span></span>
      <span></span>
    </button>

    <a href={indexHref} class="brand">
      <span class="mark">
        <span>n</span>
      </span>
      <span class="wordmark">netpack <span class="wordmark-sub">docs</span></span>
    </a>

    <nav class="links" aria-label="Site">
      <a href={homeHref}>Home</a>
      <a href={site.repoUrl} target="_blank" rel="noopener noreferrer">
        <svg viewBox="0 0 16 16" width="16" height="16" fill="currentColor" aria-hidden="true">
          <path
            d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0 0 16 8c0-4.42-3.58-8-8-8z"
          ></path>
        </svg>
        <span class="github-label">GitHub</span>
      </a>
    </nav>
  </div>
</header>

<style>
  .docs-header {
    position: relative;
    z-index: 25;
    background: var(--color-panel-bg);
    border-bottom: 1px solid var(--color-panel-border);
  }

  .docs-header-inner {
    max-width: var(--card-width);
    margin: 0 auto;
    padding: 14px var(--content-padding-x);
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .nav-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 4px;
    width: 30px;
    height: 30px;
    border: 1px solid var(--color-panel-border-strong);
    border-radius: 6px;
    background: transparent;
    cursor: pointer;
    padding: 0;
    flex-shrink: 0;
  }

  .nav-toggle span {
    display: block;
    width: 14px;
    height: 1.5px;
    margin: 0 auto;
    background: var(--color-text-body);
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    flex-shrink: 0;
  }

  .mark {
    width: 22px;
    height: 22px;
    border-radius: 6px;
    background: var(--gradient-accent);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .mark span {
    font-family: var(--font-mono);
    font-weight: 800;
    font-size: 12px;
    color: #fff;
  }

  .wordmark {
    font-family: var(--font-mono);
    font-weight: 600;
    font-size: 14px;
    color: var(--color-text-heading);
    letter-spacing: 0.01em;
    white-space: nowrap;
  }

  .wordmark-sub {
    color: var(--color-text-faint);
    font-weight: 500;
  }

  .links {
    margin-left: auto;
    display: flex;
    align-items: center;
    gap: 22px;
  }

  .links a {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--color-text-muted);
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 7px;
    transition: color 0.15s ease;
    white-space: nowrap;
  }

  .links a:hover {
    color: var(--color-text-command);
  }

  .links svg {
    flex-shrink: 0;
  }

  @media (max-width: 860px) {
    .nav-toggle {
      display: inline-flex;
    }
  }

  @media (max-width: 420px) {
    .github-label {
      display: none;
    }
  }
</style>
