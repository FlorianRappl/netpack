---
import type { DocGroup, DocSummary } from '../lib/docs';

export interface Props {
  /** docs/README.md, pinned above the grouped sections. */
  indexDoc?: DocSummary;
  groups: DocGroup[];
  current: string;
  basePrefix: string;
}

const { indexDoc, groups, current, basePrefix } = Astro.props;
---

<nav class="docs-sidebar" id="docs-sidebar" aria-label="Documentation">
  {
    indexDoc && (
      <ul class="top-level">
        <li>
          <a
            href={basePrefix}
            class:list={['link', 'overview-link', indexDoc.id === current && 'active']}
            aria-current={indexDoc.id === current ? 'page' : undefined}
          >
            Overview
          </a>
        </li>
      </ul>
    )
  }

  {
    groups.map((group) => (
      <div class="group">
        <div class="group-label">{group.label}</div>
        <ul>
          {group.docs.map((doc) => (
            <li>
              <a
                href={`${basePrefix}/${doc.id}/`}
                class:list={['link', doc.id === current && 'active']}
                aria-current={doc.id === current ? 'page' : undefined}
              >
                {doc.title}
              </a>
            </li>
          ))}
        </ul>
      </div>
    ))
  }
</nav>

<style>
  ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .top-level {
    margin-bottom: 18px;
    padding-bottom: 14px;
    border-bottom: 1px solid var(--color-panel-border);
  }

  .overview-link {
    font-weight: 600;
  }

  .group + .group {
    margin-top: 20px;
  }

  .group-label {
    font-family: var(--font-mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-faint);
    padding: 0 10px;
    margin-bottom: 6px;
  }

  .link {
    display: block;
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--color-text-body);
    text-decoration: none;
    padding: 7px 10px;
    border-radius: 5px;
    border-left: 2px solid transparent;
    transition:
      color 0.15s ease,
      background 0.15s ease,
      border-color 0.15s ease;
  }

  .link:hover {
    color: var(--color-text-command);
    background: rgba(255, 255, 255, 0.03);
  }

  .link.active {
    color: var(--color-accent-soft);
    background: rgba(124, 58, 237, 0.08);
    border-left-color: var(--color-accent);
    font-weight: 600;
  }
</style>
