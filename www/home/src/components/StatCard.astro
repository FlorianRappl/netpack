---
import Icon from './Icon.astro';
import type { StatCard as StatCardData } from '../data/content';

export interface Props {
  stat: StatCardData;
}

const { stat } = Astro.props;
---

<div class="card">
  <Icon variant={stat.icon} size={26} />
  <div class="title">{stat.title}</div>
  <div class="subtitle">{stat.subtitle}</div>
</div>

<style>
  .card {
    background: var(--color-stat-bg);
    border: 1px solid var(--color-stat-border);
    border-radius: var(--panel-radius);
    padding: 16px;
  }

  .title {
    font-family: var(--font-mono);
    font-size: 12.5px;
    color: var(--color-text-command);
    font-weight: 600;
    margin-bottom: 3px;
  }

  .subtitle {
    font-size: 11.5px;
    color: var(--color-text-muted);
    line-height: 1.5;
  }
</style>
